<?xml version="1.0" encoding="utf-8"?>
<rss version="2.0" xmlns:sparkle="http://www.andymatuschak.org/xml-namespaces/sparkle">
  <channel>
    <title>Halo</title>
    <link>https://tinkerhaus.github.io/halo/</link>
    <description>Updates for Halo — the mouse-summoned radial command wheel.</description>
    <language>en</language>
    <!--
      Halo ships self-signed / un-notarized. A self-signed build has no Team ID, so
      macOS App Management won't grant the self-update exemption and blocks Sparkle
      from installing an update in place. Updates are therefore INFORMATIONAL: each
      item omits the enclosure element, so Sparkle just notifies the user and links
      them to the download (they install manually). To publish a release: copy the
      item, bump sparkle:version (= CFBundleVersion) and shortVersionString, and
      point the link element at the release. No enclosure, length, or signature.
    -->
    <item>
      <title>Halo 0.1.0</title>
      <link>https://github.com/tinkerhaus/halo/releases/latest</link>
      <sparkle:version>1</sparkle:version>
      <sparkle:shortVersionString>0.1.0</sparkle:shortVersionString>
      <sparkle:minimumSystemVersion>14.0</sparkle:minimumSystemVersion>
      <description><![CDATA[
        <p>First public release: a mouse-summoned radial command wheel with on-device voice dictation at its center.</p>
        <p>Download the latest Halo from the releases page and drag it into Applications.</p>
      ]]></description>
    </item>
  </channel>
</rss>
